DATABASE_URL=postgresql://root:root@localhost:5432/carsi

# ===========================================
# PROJECT CONFIGURATION
# ===========================================
PROJECT_NAME=my-project
NODE_ENV=development

# ===========================================
# DATABASE (PostgreSQL - Local by default)
# ===========================================
# Local PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://starter_user:local_dev_password@localhost:5433/starter_db

# For production, use your PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:5432/database

# ===========================================
# AUTHENTICATION (JWT)
# ===========================================
# IMPORTANT: Change this secret key in production!
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
JWT_EXPIRE_MINUTES=60

# Webhook signature secret (used for HMAC-SHA256 verification)
WEBHOOK_SECRET=CHANGE_ME

# ===========================================
# AI MODELS (All Optional - Ollama used by default)
# ===========================================
# AI Provider: "ollama" (local) or "anthropic" (cloud)
AI_PROVIDER=ollama

# Ollama Configuration (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Anthropic (Claude) - Optional cloud provider
# ANTHROPIC_API_KEY=sk-ant-xxx

# Google (Gemini) - Optional
# GOOGLE_AI_API_KEY=xxx

# OpenRouter (Multi-model access) - Optional
# OPENROUTER_API_KEY=sk-or-xxx

# ===========================================
# MCP TOOLS
# ===========================================
# Exa (Web Search)
EXA_API_KEY=xxx

# Ref.tools
REF_TOOLS_API_KEY=xxx

# ===========================================
# FRONTEND
# ===========================================
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info

# ===========================================
# DEPLOYMENT (DigitalOcean)
# ===========================================
DO_APP_ID=your-app-id
DO_API_TOKEN=your-do-token
DIGITALOCEAN_API=your-do-token

# ===========================================
# JINA AI (Web Reading / Scraping)
# ===========================================
# Get from: https://jina.ai/
JINA_API_KEY=your-jina-api-key

# ===========================================
# STRIPE (Payments & Billing)
# ===========================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===========================================
# LINEAR (Project Management - MCP Server)
# ===========================================
# Get from: https://linear.app/YOUR-TEAM/settings/api
LINEAR_API_KEY=your-linear-api-key

# ===========================================
# WOOCOMMERCE (WordPress Migration)
# ===========================================
# Get from: WordPress Admin > WooCommerce > Settings > Advanced > REST API
# Only needed for wp:migrate script
WC_CONSUMER_KEY=ck_xxx
WC_CONSUMER_SECRET=cs_xxx

# ===========================================
# ADMIN (dashboard at /admin)
# ===========================================
# Server-only (used by /api/admin/login). Quote values if they contain # or spaces.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
# Optional: comma-separated LMS emails that may use /login then /admin (without /api/admin/login).
# Also allowed: any LMS user with JWT role `admin` (see lms_roles / lms_user_roles).
# ADMIN_PANEL_EMAILS=support@example.com
# Optional: same email shown on the admin login form in the browser (NEXT_PUBLIC_* is bundled for the client).
# NEXT_PUBLIC_ADMIN_EMAIL=you@example.com
