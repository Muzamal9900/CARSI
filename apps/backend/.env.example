# =============================================================================
# CARSI LMS Backend — Environment Variables
# Copy to .env.local for local development
# =============================================================================

# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================
DATABASE_URL=postgresql://carsi_user:carsi_dev_pass@localhost:5433/carsi_dev
POSTGRES_USER=carsi_user
POSTGRES_PASSWORD=carsi_dev_pass
POSTGRES_DB=carsi_dev

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6380

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET_KEY=change-me-in-production-min-48-chars
JWT_EXPIRE_MINUTES=60

# =============================================================================
# API Configuration
# =============================================================================
BACKEND_API_KEY=your_backend_api_key_here
CORS_ORIGINS=["http://localhost:3000","http://localhost:3009"]
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# AI Provider — Ollama (local, free) or Anthropic (cloud)
# =============================================================================
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# EMAIL — SMTP Configuration
# =============================================================================
# Local development: Mailpit (Docker) — no auth, no TLS
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_USE_TLS=false
#   SMTP_USE_SSL=false
#
# Production: Resend SMTP (recommended)
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxx (your Resend API key)
#   SMTP_USE_SSL=true
#
# Production: Standard SMTP (port 587 STARTTLS)
#   SMTP_HOST=smtp.your-provider.com
#   SMTP_PORT=587
#   SMTP_USER=noreply@carsi.com.au
#   SMTP_PASS=your_password
#   SMTP_USE_TLS=true
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@carsi.com.au
SMTP_FROM_NAME=CARSI Learning
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# =============================================================================
# Google Drive Integration (OAuth2)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_DRIVE_FOLDER_ID=

# =============================================================================
# Stripe Payments
# =============================================================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_GOOGLE_DRIVE=false
FEATURE_AI_RECOMMENDATIONS=false
FEATURE_PAYMENTS=false
