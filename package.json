{
  "name": "claude-agent-orchestration-template",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready monorepo for AI-powered applications with Next.js, LangGraph, and Claude",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "pnpm -r --filter \"./packages/*\" run build && next build",
    "lint": "eslint .",
    "type-check": "pnpm -r --filter \"./packages/*\" run type-check && tsc --noEmit",
    "clean": "rm -rf node_modules .next",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "deps:check": "node -e \"console.log('deps:check: no scripts/dependency-checks.sh (removed).')\"",
    "deps:sync": "pnpm install",
    "deps:clean": "pnpm prune && pnpm install",
    "ai:models:check": "npx ts-node src/ai/version-checks/check-model-currency.ts",
    "ai:visual:audit": "npx ts-node src/ai/audits/visual-audit.ts",
    "ai:finished:audit": "bash templates/governance-framework/governance-check.sh && npx ts-node src/ai/audits/visual-audit.ts",
    "ai:governance:check": "bash templates/governance-framework/governance-check.sh",
    "starter:audit": "node -e \"console.log('starter:audit: script removed.')\"",
    "starter:adopt": "node -e \"console.log('starter:adopt: script removed.')\"",
    "wp:migrate": "npx ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/wp-migrate.ts",
    "wp:migrate:dry-run": "npx ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/wp-migrate.ts --dry-run",
    "wp:redirects": "node -e \"console.log('wp:redirects: generate-redirects.ts removed; use wp:migrate output (url-redirects.json).')\"",
    "wp:seed": "node -e \"console.log('wp:seed: no in-repo backend; use wp:migrate or add scripts/wordpress-seed.ts if needed.')\"",
    "start": "next start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.49.1",
    "@surma/rollup-plugin-off-main-thread": "^2.2.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.0",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "6.19.2",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "6.19.2",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@xyflow/react": "^12.10.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dots-wrapper": "^3.12.6",
    "framer-motion": "^12.29.0",
    "isomorphic-dompurify": "^3.0.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.468.0",
    "next": "^16.1.1",
    "next-pwa": "^5.6.0",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.1",
    "react-hot-toast": "^2.6.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.5.1",
    "stripe": "^20.2.0",
    "tailwind-merge": "^2.6.0",
    "uuid": "^13.0.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29",
    "zod": "^3.24.1",
    "zustand": "^5.0.10"
  }
}
